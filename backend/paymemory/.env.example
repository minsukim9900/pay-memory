# server
SERVER_PORT=8080

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pay_memory
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JPA
JPA_DDL_AUTO=update

# Kakao OAuth2
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8080/login/oauth2/code/kakao

# JWT
JWT_SECRET=change-me-to-long-random-secret
JWT_ACCESS_TOKEN_NAME=ACCESS_TOKEN
JWT_ACCESS_TOKEN_EXPIRE=3600000
JWT_REFRESH_TOKEN_NAME=REFRESH_TOKEN
JWT_REFRESH_TOKEN_EXPIRE=1209600000

COOKIE_DOMAIN=paymemory.site
OAUTH2_SUCCESS_REDIRECT_URL=https://paymemory.site